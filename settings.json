{
  "env": {
    "ANTHROPIC_BASE_URL": "https://new-api.jointpilot.com",
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL_NAME": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "kimi-k2.6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_NAME": "kimi-k2.6",
    "ANTHROPIC_MODEL": "kimi-k2.6",
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8",
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1",
    "MSYS2_ARG_CONV_EXCL": "*",
    "CHERE_INVOKING": "1"
  },
  "permissions": {
    "allow": [
      "=== [ALLOW] 1. 原生核心原子操作（全面覆盖 Read/Search 及其衍生变体） ===",
      "Read",
      "Read(*)",
      "Search",
      "Search(*)",
      "=== [ALLOW] 2. 基础与深度树状文件系统审计（全面覆盖 ls/find/stat/du/cd 串联） ===",
      "Bash(*ls*)",
      "Bash(*find*)",
      "Bash(*echo*)",
      "Bash(*cat*)",
      "Bash(*tail*)",
      "Bash(*stat*)",
      "Bash(*du*)",
      "Bash(*mkdir*)",
      "Bash(*cd*)",
      "Bash(*where*)",
      "Bash(*which*)",
      "=== [ALLOW] 3. 跨平台打包压缩与多阶段重定向管道（全面覆盖 tar/gzip/sed/grep/tee） ===",
      "Bash(*tar*)",
      "Bash(*gunzip*)",
      "Bash(*sed*)",
      "Bash(*grep*)",
      "Bash(*tee*)",
      "Bash(*xargs*)",
      "Bash(*basename*)",
      "Bash(*head*)",
      "Bash(*|*)",
      "Bash(*&&*)",
      "Bash(*2>/dev/null*)",
      "Bash(*||*)",
      "Bash(*2>&1*)",
      "Bash(*(*)*)",
      "=== [ALLOW] 4. 高阶运维控制、宿主进程审计、网络穿透与分布式凭证链路 ===",
      "Bash(*chmod*)",
      "Bash(*ssh*)",
      "Bash(*sshpass*)",
      "Bash(*pkill*)",
      "Bash(*df*)",
      "Bash(*env*)",
      "Bash(*ASCEND_HOME*)",
      "Bash(*npu-smi*)",
      "Bash(*torch_npu*)",
      "=== [ALLOW] 5. 跨平台通用系统架构隔离区、临时快照及专属技能树无感读写 ===",
      "Write(*SKILL.md*)",
      "=== [ALLOW] 6. 现代版本控制系统、多阶段容器集群编排与异构镜像导出 ===",
      "Bash(*git*)",
      "Bash(*gh*)",
      "Bash(*docker*)",
      "Bash(*DOCKER_TMPDIR*)",
      "Bash(*systemctl*)",
      "Bash(*journalctl*)",
      "=== [ALLOW] 7. 全自动化环境依赖构建、跨平台包管系统及多版本 Python 解释器 ===",
      "Bash(*npm*)",
      "Bash(*pytest*)",
      "Bash(*apt-get*)",
      "Bash(*yum*)",
      "Bash(*choco*)",
      "Bash(*python*)",
      "Bash(*pip*)",
      "Bash(*PYTHONUTF8*)",
      "Bash(*py_compile*)",
      "=== [ALLOW] 8. 自动化多分支 Shell 循环控制流与无弹窗高危内联脚本流 ===",
      "Bash(*for*)",
      "Bash(*while*)",
      "Bash(*do*)",
      "Bash(*import*)",
      "Bash(*<<*)",
      "Bash(*ssh_exec.py*)",
      "Bash(*PYEOF*)",
      "Bash(*paramiko*)",
      "=== [ALLOW] 9. 全平台无损自动化高维物理备份与原子级重命名操作 ===",
      "Bash(*cp*)",
      "Bash(*mv*)",
      "Bash(*Copy-Item*)",
      "Bash(*Move-Item*)",
      "=== [ALLOW] 10. 外网全域自动化网络资源、高阶知识库与安全套接字拉取 ===",
      "Bash(*curl*)",
      "Fetch(*arxiv.org*)",
      "Fetch(*github.com*)",
      "Fetch(*githubusercontent.com*)",
      "Fetch(*gitee.com*)",
      "Web Search",
      "Web Search(*)",
      "=== [ALLOW] 11. 穿透 Windows 绝对路径与全域宿主特权目录 ===",
      "Read(C:/**)",
      "Read(D:/**)",
      "Write(C:/**)",
      "Write(D:/**)",
      "Bash(*:/*)",
      "Bash(*/c/*)",
      "Bash(*/d/*)",
      "Search(pattern: *, path: *)",
      "=== [ALLOW] 12. 解除专属工具箱与 SKILL.md 特权生命周期限制 ===",
      "Write(**/SKILL.md)",
      "=== [ALLOW] 13. 放行全新系统级分析算子及异构十六进制工具链 ===",
      "Bash(*xxd*)",
      "=== [ALLOW] 14. 兼容重型进程替换 (Process Substitution) 与高级异步重定向 ===",
      "Bash(*diff*<(*)*<(*)*)",
      "Bash(*v*.bak*)",
      "Bash(*.orig*)",
      "Bash(*cd * && *cp*)"
    ],
    "deny": [
      "=== [DENY] 1. 终极红线：严禁损坏操作系统与控制核心 ===",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .git)",
      "Bash(reboot)",
      "Bash(shutdown *)",
      "Bash(format *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "=== [DENY] 2. 严禁越权窃取主机本地全局环境与云凭证 ===",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.config/*)",
      "Read(~/.bashrc)",
      "Read(~/.zshrc)",
      "=== [DENY] 3. 严格禁止探测本地应用私密令牌与持久数据库 ===",
      "Read(./.env*)",
      "Bash(cat .env*)",
      "Read(./instance/config.py)",
      "Read(./secrets.json)",
      "Read(./*.db)",
      "Read(./*.sqlite*)",
      "Read(./dump.rdb)",
      "=== [DENY] 4. 防篡改：禁止模型覆写核心部署流水线与关键配置 ===",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(./docker-compose.override.yml)",
      "Write(settings.json)",
      "Write(.gitlab-ci.yml)",
      "=== [DENY] 5. 性能屏障：屏蔽大型依赖和本地编译缓存，节省 Token ===",
      "Read(./venv/*)",
      "Read(./.venv/*)",
      "Read(./__pycache__/*)",
      "Read(./.pytest_cache/*)",
      "Read(./*.egg-info/*)",
      "Read(./build/*)"
    ],
    "defaultMode": "acceptEdits",
    "_comment_defaultMode": "【权限模式预设】允许自动接受代码文件修改（不弹窗），但执行危险未知的 Bash 命令时仍会询问确认"
  },
